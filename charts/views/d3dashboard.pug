doctype html
html
  head
    title D3 Cosmic Dashboard
    meta(charset="UTF-8")
    script(src="https://d3js.org/d3.v7.min.js")
    style.
      body{
        background:#020617;
        color:white;
        font-family:Arial;
        padding:20px
        }
      h1{
        text-align:center;
        color:#a78bfa
        }
      .grid{
        display:grid;
        grid-template-columns:repeat(auto-fit,minmax(450px,1fr));
        gap:20px
        }
      .card{
        background:#111827;
        padding:20px;
        border-radius:15px
        }
      svg{
        width:100%;
        height:320px;
        background:#0f172a;
        border-radius:10px
        }
  body
    h1 D3.js Dashboard
    .grid
      .card
        h2 Bar Chart
        svg#bar
      .card
        h2 Line Chart
        svg#line
      .card
        h2 Scatter Plot
        svg#scatter

    script.
      const data=[40,80,60,100];
      const svg=d3.select('#bar');
      svg.selectAll('rect').data(data).enter().append('rect')
      .attr('x',(d,i)=>i*90+40)
      .attr('y',d=>300-d*2)
      .attr('width',50)
      .attr('height',d=>d*2)
      .attr('fill','#a78bfa');

      const lineSvg=d3.select('#line');
      const line=d3.line()
        .x((d,i)=>i*100+50)
        .y(d=>300-d*2);
      lineSvg.append('path')
        .datum(data)
        .attr('d',line)
        .attr('stroke','#22c55e')
        .attr('stroke-width',4)
        .attr('fill','none');

      const scatter=[{x:50,y:100},{x:120,y:200},{x:250,y:140}];
      const scatterSvg=d3.select('#scatter');
      scatterSvg.selectAll('circle').data(scatter).enter().append('circle')
        .attr('cx',d=>d.x)
        .attr('cy',d=>300-d.y)
        .attr('r',8)
        .attr('fill','#f97316');
