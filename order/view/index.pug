doctype html
html
head
title User List

// DataTables CSS
link(rel="stylesheet", href="https://cdn.datatables.net/1.13.6/css/jquery.dataTables.min.css")
link(rel="stylesheet", href="https://cdn.datatables.net/buttons/2.4.1/css/buttons.dataTables.min.css")

style.
  body {
    font-family: Arial, sans-serif;
    background: #f4f6f9;
    margin: 0;
    padding: 20px;
  }


  h3 {
    margin-bottom: 15px;
    font-weight: 600;
  }

  .top-bar {
    display: flex;
    justify-content: flex-end;
    align-items: center;
    margin-bottom: 15px;
  }

  .checkbox-group {
    display: flex;
    gap: 15px;
    align-items: center;
    font-size: 14px;
  }

  .actions {
    display: flex;
    gap: 10px;
  }

  .actions button {
    background: #f0a74b;
    border: none;
    padding: 8px 14px;
    color: #fff;
    border-radius: 5px;
    cursor: pointer;
    font-size: 13px;
  }

  .actions button:hover {
    background: #e6952f;
  }

  .filter {
    display: flex;
    align-items: center;
    gap: 10px;
    margin-bottom: 15px;
  }

  .filter select {
    padding: 6px 10px;
    border: 1px solid #ccc;
    border-radius: 4px;
  }

  .filter button {
    background: #ee9b35;
    border: none;
    padding: 7px 14px;
    color: #fff;
    border-radius: 5px;
    cursor: pointer;
  }

  .dataTables_wrapper {
    font-size: 13px;
  }

  table.dataTable thead {
    background: #f9fafb;
  }

  table.dataTable thead th {
    padding: 10px;
    border-bottom: 2px solid #ddd;
    font-weight: 600;
  }

  table.dataTable tbody td {
    padding: 10px;
    border-bottom: 1px solid #eee;
  }

  table.dataTable tbody tr:hover {
    background-color: #f1f7ff;
  }

  /* Status badge */
  .badge-active {
    background: #28a745;
    color: #fff;
    padding: 3px 8px;
    border-radius: 4px;
    font-size: 12px;
  }
  .badge-inactive {
  background: #dc3545;
  color: #fff;
  padding: 3px 8px;
  border-radius: 4px;
  font-size: 12px;
  }
  /* Action button */
  .btn-edit {
    background: #e9ecef;
    border: 1px solid #ccc;
    padding: 5px 10px;
    border-radius: 4px;
    cursor: pointer;
  }

  .btn-edit:hover {
    background: #d6d8db;
  }

  /* DataTables buttons */
  .dt-buttons .dt-button {
    background: #f1f3f5 ;
    border: 1px solid #ccc ;
    border-radius: 4px;
    padding: 5px 10px ;
    font-size: 12px ;
  }

  .dt-buttons .dt-button:hover {
    background: #e2e6ea ;
  }
  /* Modal background */
  .modal {
    display: none;
    position: fixed;
    z-index: 999;
    left: 0;
    top: 0;
    width: 100%;
    height: 100%;
    background: rgba(0,0,0,0.5);
  }

  /* Modal box */
  .modal-content {
    background: #fff;
    width: 400px;    
    margin: 1% auto;
    padding: 20px;
    border-radius: 8px;
    max-height: 80vh;
    position: relative;
  }
  .modal-content form{
    max-width: 500px; 
    right-margin: 10px;
    height:100hv;
    justify-content:center;
    align-items:center;
  }
  .modal-content h3{
    marigin-top: -5px
    marigin-bottom:-5px;
    text-align: center;
  }
  .modal-content label{
    display: block;
    font-size: 13px;
    margin-top: 1px;
    text-align:left; 
  } 

  .modal-content input,.modal-content select{
    width:90%; 
    padding: 4px; 
    margin-top: 5px; 
    text-align:left;
  }
  .modal-content select{
    width:94%;
  }
  .modal-content .actions{
    margin-top: 15px; 
    display:flex;
    justify-content:flex-end;
    gap:10px;
  }
  /* Close button */
  .close {
    position: absolute;
    right: 10px;
    top: 5px;
    font-size: 22px;
    cursor: pointer;
  }
  #orderTable {
    width: 100% !important;
  }

  .dataTables_wrapper {
    overflow-x: auto;
  }
body

h3 ORDER LIST 

  .top-bar
    .actions
      button#addnewItem Add New Order +

  
  table#orderTable.display(style="width:100%")
    thead 
      tr 
        th Item 
        th Ord.Qty 
        th Ord.Cost
        th Ord.Taxless Total
        th Ord.SGST %
        th Ord.SGST ₹
        th Ord.CGST %
        th Ord.CGST ₹
        th Ord.Total.GST ₹
        th Ord.GST Total
        th Ord.Net Total
        th Inv.Qty
        th Inv.Cost
        th Inv.GST %
        th Inv.SGST %
        th Inv.SGST ₹
        th Inv.CGST %
        th Inv.CGST ₹
        th Inv.Total.GST ₹
        th Discount %
        th Discount.Cost
        th Inv.Taxless Total
        th Inv.GST Total
        th Inv.Net Total
    tbody 
      each o in orders 
        tr  
          td= o.item 
          td= o.ordQty
          td= o.ordCost
          td= o.ordTaxlessTotal
          td= o.ordSGST
          td= o.ordSGSTRs
          td= o.ordCGST
          td= o.ordCGSTRs
          td= o.ordTotalGST
          td= o.ordGSTTotal
          td= o.ordNetTotal
          td= o.invQty
          td= o.invCost
          td= o.invGST
          td= o.invSGST
          td= o.invSGSTRs
          td= o.invCGST
          td= o.invCGSTRs
          td= o.invTotalGST
          td= o.discount
          td= o.discountCost
          td= o.invTaxlessTotal
          td= o.invGSTTotal
          td= o.invNetTotal


// ORDER MODAL
#orderModal.modal
  .modal-content(style="max-height:90vh; overflow-y:auto;")
    span.close ×

    h3#orderFormTitle Add New Order

    form#orderForm(method="POST" action="/orders")

      input(type="hidden" name="id" id="orderId")

      label Item
      input(type="text" name="item" id="item" required)

      label Ord.Qty
      input(type="number" name="ordQty" id="ordQty")

      label Ord.Cost
      input(type="number" step="0.01" name="ordCost" id="ordCost")

      label Ord.Taxless Total
      input(type="number" step="0.01" name="ordTaxlessTotal" id="ordTaxlessTotal")

      label Ord.SGST %
      input(type="number" step="0.01" name="ordSGST" id="ordSGST")

      label Ord.SGST ₹
      input(type="number" step="0.01" name="ordSGSTRs" id="ordSGSTRs")

      label Ord.CGST %
      input(type="number" step="0.01" name="ordCGST" id="ordCGST")

      label Ord.CGST ₹
      input(type="number" step="0.01" name="ordCGSTRs" id="ordCGSTRs")

      label Ord.Total.GST ₹
      input(type="number" step="0.01" name="ordTotalGST" id="ordTotalGST")

      label Discount %
      input(type="number" step="0.01" name="discount" id="discount")

      label Discount.Cost
      input(type="number" step="0.01" name="discountCost" id="discountCost")

      label Ord.GST Total
      input(type="number" step="0.01" name="ordGSTTotal" id="ordGSTTotal")

      label Ord.Net Total
      input(type="number" step="0.01" name="ordNetTotal" id="ordNetTotal")

      label Inv.Qty
      input(type="number" step="0.01" name="invQty" id="invQty")

      label Inv.Cost
      input(type="number" step="0.01" name="invCost" id="invCost")
      
      label Inv.Taxless Total
      input(type="number" step="0.01"  name="invTaxlessTotal" id="invTaxlessTotal")

      label Inv.SGST %
      input(type="number" step="0.01" name="invSGST" id="invSGST")

      label Inv.SGST ₹
      input(type="number" step="0.01" name="invSGSTRs" id="invSGSTRs")

      label Inv.CGST %
      input(type="number" step="0.01" name="invCGST" id="invCGST")

      label Inv.CGST ₹
      input(type="number" step="0.01" name="invCGSTRs" id="invCGSTRs")

      label Inv.Total.GST ₹
      input(type="number" step="0.01" name="invTotalGST" id="invTotalGST")

      label Inv.GST Total
      input(type="number" step="0.01"  name="invGSTTotal" id="invGSTTotal")

      label Inv.Net Total
      input(type="number" step="0.01" name="invNetTotal" id="invNetTotal")

      .actions
        button(type="submit" id="orderSubmitBtn") Submit
        button(type="reset") Reset


script(src="https://code.jquery.com/jquery-3.7.1.min.js")
script(src="https://cdn.datatables.net/1.13.6/js/jquery.dataTables.min.js")
script(src="https://cdn.datatables.net/buttons/2.4.1/js/dataTables.buttons.min.js")
script(src="https://cdnjs.cloudflare.com/ajax/libs/jszip/3.10.1/jszip.min.js")
script(src="https://cdn.datatables.net/buttons/2.4.1/js/buttons.html5.min.js")


