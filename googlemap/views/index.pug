doctype html
html(lang="en")
  head
    meta(charset="UTF-8")
    meta(name="viewport" content="width=device-width, initial-scale=1.0")

    title VehiTracker

    link(rel="preconnect" href="https://fonts.googleapis.com")
    link(rel="preconnect" href="https://fonts.gstatic.com" crossorigin)

    link(
      href="https://fonts.googleapis.com/css2?family=DM+Sans:ital,opsz,wght@0,9..40,400;0,9..40,500;0,9..40,600;0,9..40,700;1,9..40,400&display=swap"
      rel="stylesheet"
    )

    style.
      * {
        margin: 0;
        padding: 0;
        box-sizing: border-box;
      }

      body {
        font-family: 'DM Sans', sans-serif;
        overflow: hidden;
        background: #111827;
      }

      #map {
        width: 100%;
        height: 100vh;
      }
      .topbar {
        position: absolute;
        margin-top:35px;
        top: 18px;        
        left: 18px;
        right: 18px;
        display: flex;
        align-items: flex-start;
        gap: 14px;
        z-index: 50;
        flex-wrap: wrap;
      }
      .search-box {
        width: 480px;
        height: 50px;
        display: flex;
        align-items: center;
        gap: 16px;
        padding: 0 20px;
        background: rgba(255,255,255,.97);
        border-radius: 36px;
        box-shadow: 0 4px 18px rgba(0,0,0,.18);
      }

      .search-icon {
        width: 22px;
        height: 22px;
        stroke: #5f6368;
        stroke-width: 2;
        fill: none;
        flex-shrink: 0;
      }

      .search-box input {
        flex: 1;
        border: none;
        outline: none;
        background: none;
        font-size: 16px;
        font-family: inherit;
        color: #202124;
      }

      .search-box input::placeholder { color: #9ca3af; }

      .direction-btn {
        width: 32px;
        height: 32px;
        border: none;
        border-radius: 50%;
        background: #1a6e0f;
        display: flex;
        align-items: center;
        justify-content: center;
        cursor: pointer;
        flex-shrink: 0;
        transition: background .18s;
      }

      .direction-btn:hover { background: #145a09; }

      .direction-btn svg {
        width: 16px;
        height: 16px;
        stroke: white;
        stroke-width: 2.2;
        fill: none;
      }
      .chip-row {
        display: flex;
        align-items: center;
        gap: 10px;
        overflow-x: auto;
        padding-bottom: 2px;
        margin-top: 8px;
      }

      .chip-row::-webkit-scrollbar { display: none; }

      .map-chip {
        height: 40px;
        padding: 0 20px;
        border: none;
        background: rgba(255,255,255,.97);
        border-radius: 999px;
        display: flex;
        align-items: center;
        gap: 8px;
        font-size: 14px;
        font-weight: 500;
        font-family: inherit;
        color: #202124;
        cursor: pointer;
        white-space: nowrap;
        box-shadow: 0 2px 10px rgba(0,0,0,.14);
        transition: transform .15s ease, box-shadow .15s ease, background .15s;
      }

      .map-chip:hover {
        transform: translateY(-2px);
        box-shadow: 0 6px 18px rgba(0,0,0,.16);
        background: #fff;
      }
      .hint-banner {
        position: absolute;
        top: 80px;
        left: 50%;
        transform: translateX(-50%);
        background: rgba(30,30,30,.82);
        color: #fff;
        font-size: 13px;
        padding: 8px 20px;
        border-radius: 999px;
        z-index: 48;
        pointer-events: none;
        opacity: 1;
        transition: opacity 1s ease;
        white-space: nowrap;
      }

      .hint-banner.hidden { opacity: 0; }

      .dir-panel {
        position: absolute;
        top: 80px;
        left: 20px;
        width: 380px;
        background: rgba(255,255,255,.98);
        border-radius: 24px;
        box-shadow: 0 10px 32px rgba(0,0,0,.22);
        padding: 20px;
        display: none;
        flex-direction: column;
        gap: 18px;
        z-index: 70;
      }

      .dir-panel.active { display: flex; }

      .dir-top-modes {
        display: flex;
        align-items: center;
        gap: 10px;
        padding-bottom: 16px;
        border-bottom: 1px solid rgba(0,0,0,.08);
      }

      .dir-mode {
        width: 50px;
        height: 50px;
        border: none;
        border-radius: 50%;
        background: transparent;
        font-size: 22px;
        cursor: pointer;
        transition: .18s ease;
      }

      .dir-mode:hover { background: rgba(0,0,0,.06); }
      .dir-mode.active { background: #d9f2ff; }

      .dir-close {
        margin-left: auto;
        width: 42px;
        height: 42px;
        border: none;
        border-radius: 50%;
        background: #f3f4f6;
        font-size: 18px;
        cursor: pointer;
        transition: background .15s;
      }

      .dir-close:hover { background: #e5e7eb; }

      .dir-inputs { display: flex; gap: 16px; }

      .dir-side-icons {
        width: 24px;
        display: flex;
        flex-direction: column;
        align-items: center;
        padding-top: 22px;
      }

      .dot {
        width: 13px;
        height: 13px;
        border: 3px solid #202124;
        border-radius: 50%;
      }

      .line {
        width: 2px;
        flex: 1;
        background: rgba(0,0,0,.18);
        margin: 6px 0;
      }

      .pin {
        width: 14px;
        height: 14px;
        background: #ea4335;
        border-radius: 50% 50% 50% 0;
        transform: rotate(-45deg);
        position: relative;
      }

      .pin::after {
        content: "";
        position: absolute;
        width: 5px;
        height: 5px;
        border-radius: 50%;
        background: white;
        top: 4px;
        left: 4px;
      }

      .dir-fields {
        flex: 1;
        display: flex;
        flex-direction: column;
        gap: 12px;
        position: relative;
      }

      .dir-input-wrap {
        width: 95%;
        height: 54px;
        border: 1px solid rgba(0,0,0,.16);
        border-radius: 14px;
        padding: 0 16px;
        display: flex;
        align-items: center;
        background: white;
        transition: border-color .2s;
      }

      .dir-input-wrap:focus-within { border-color: #1a6e0f; }

      .dir-input-wrap input {
        width: 100%;
        border: none;
        outline: none;
        background: none;
        font-size: 15px;
        font-family: inherit;
        color: #202124;
      }

      .dir-input-wrap input::placeholder { color: #9ca3af; }

      .swap-btn {
        position: absolute;
        right: -18px;
        top: 50%;
        transform: translateY(-50%);
        width: 38px;
        height: 38px;
        border: none;
        border-radius: 50%;
        background: white;
        box-shadow: 0 2px 10px rgba(0,0,0,.16);
        font-size: 18px;
        cursor: pointer;
        transition: box-shadow .15s, transform .2s;
      }

      .swap-btn:hover {
        box-shadow: 0 4px 14px rgba(0,0,0,.2);
        transform: translateY(-50%) rotate(180deg);
      }

      #info {
        position: absolute;
        bottom: 24px;
        left: 50%;
        transform: translateX(-50%);
        background: rgba(255,255,255,.97);
        border-radius: 999px;
        padding: 10px 22px;
        display: none;
        align-items: center;
        gap: 10px;
        box-shadow: 0 4px 20px rgba(0,0,0,.16);
        z-index: 50;
        white-space: nowrap;
      }

      .info-inline {
        display: flex;
        align-items: center;
        gap: 10px;
      }

      .info-emoji { font-size: 20px; }
      .info-mode  { font-weight: 600; font-size: 14px; color: #202124; }
      .info-dot   { color: #9ca3af; font-size: 12px; }

      .info-duration,
      .info-distance {
        font-size: 14px;
        color: #374151;
      }

      .info-duration { font-weight: 600; }

      .info-spinner {
        width: 18px;
        height: 18px;
        border: 2.5px solid #e5e7eb;
        border-top-color: #1a6e0f;
        border-radius: 50%;
        animation: spin .7s linear infinite;
        display: inline-block;
      }

      @keyframes spin { to { transform: rotate(360deg); } }
      @media (max-width: 900px) {
        .topbar { flex-direction: column; align-items: stretch; }
        .search-box { width: 100%; }
        .chip-row { margin-top: 0; }
        .dir-panel { width: calc(100% - 40px); }
        .swap-btn { right: -6px; }
      }

    script(src="https://unpkg.com/@googlemaps/markerclusterer/dist/index.min.js")
    script(src="/js/map.js")
    script(
      src=`https://maps.googleapis.com/maps/api/js?key=${apiKey}&libraries=places,geometry&callback=initMap`
      async
      defer
    )

  body

    #map


    .topbar

      .search-box
        svg.search-icon(viewBox="0 0 24 24")
          circle(cx="11" cy="11" r="7")
          line(x1="20" y1="20" x2="16.5" y2="16.5")
        input#city(type="text" placeholder="Search Google Maps")
        button.direction-btn(onclick="toggleDirections()" title="Get directions")
          svg(viewBox="0 0 24 24")
            path(d="M5 12h14")
            path(d="M12 5l7 7-7 7")


      .chip-row
        button.map-chip(onclick="searchNearby('car_repair')")    🔧 Workshop
        button.map-chip(onclick="searchNearby('gas_station')")   ⛽ Fuel Stations
        button.map-chip(onclick="searchNearby('pharmacy')")      💊 Pharmacy
        button.map-chip(onclick="searchNearby('hospital')")      🏥 Hospital
        button.map-chip(onclick="toggleTraffic()")    🚦 Traffic

    .dir-panel#dirPanel
      .dir-top-modes
        button.dir-mode.active(data-mode="driving"   onclick="selectMode(this)") ⛟
        button.dir-mode(       data-mode="bicycling" onclick="selectMode(this)") 🚲
        button.dir-mode(       data-mode="transit"   onclick="selectMode(this)") 🚆
        button.dir-mode(       data-mode="walking"   onclick="selectMode(this)") 🚶
        button.dir-close(onclick="toggleDirections()") ✕

      .dir-inputs
        .dir-side-icons
          .dot
          .line
          .pin

        .dir-fields
          .dir-input-wrap
            input#from(type="text" placeholder="Choose starting point")
          .dir-input-wrap
            input#to(type="text" placeholder="Choose destination")
          button.swap-btn(onclick="swapLocations()" type="button") ⇅

      input#modeInput(type="hidden" value="driving")

    #info

    script.
      setTimeout(() => {
        const b = document.getElementById('hintBanner');
        if (b) {
          b.classList.add('hidden');
          setTimeout(() => b.remove(), 1000);
        }
      }, 4000);

      function toggleDirections() {
        document.getElementById('dirPanel').classList.toggle('active');
      }
